{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(./gradlew)",
      "Bash(docker compose *)",
      "Bash(docker ps)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker exec *)",
      "Bash(docker images)",
      "Bash(docker images *)",
      "Bash(docker network ls)",
      "Bash(docker network inspect *)",
      "Bash(docker volume ls)",
      "Bash(docker inspect *)",
      "Bash(docker --version)",
      "Bash(docker compose version)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(curl http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -i http://localhost:*)",
      "Bash(curl -X * http://localhost:*)",
      "Bash(java -version)",
      "Bash(gradle -version)",
      "Bash(jq *)",
      "Bash(tree)",
      "Bash(tree *)"
    ],
    "deny": [
      "Bash(docker system prune *)",
      "Bash(docker volume prune *)",
      "Bash(docker image prune *)",
      "Bash(docker rm -f *)",
      "Bash(docker rmi -f *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)"
    ]
  }
}
